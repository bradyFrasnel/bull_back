# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bull_asur_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Frontend URL (mettre 'true' pour accepter toutes les origines en développement)
FRONTEND_URL="true"

# Server (port d'écoute)
PORT=3002

# Network configuration
# Pour écouter sur toutes les interfaces réseau (0.0.0.0)
# Décommenter la ligne suivante pour le développement réseau
# HOST=0.0.0.0
