# Database (Prisma)
# Local Postgres :
# DATABASE_URL="postgresql://username:password@localhost:5432/bull_asur_db"
#
# Supabase — dev local (souvent plus fiable que le port 6543) :
#   → Dashboard → Project Settings → Database → « Session pooler » (port 5432)
#   → ou « Direct connection » (port 5432, IP autorisée si activée)
#
# Supabase — Transaction pooler (port 6543, souvent utilisé sur Render) :
#   → ajouter en fin d’URL : ?pgbouncer=true
#   → peut être bloqué par VPN / pare-feu en local
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
DATABASE_URL="postgresql://username:password@localhost:5432/bull_asur_db"
DIRECT_URL="postgresql://username:password@localhost:5432/bull_asur_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Environment
NODE_ENV="production"

# Frontend URL (liste séparée par des virgules en prod, ou 'true' en dev)
FRONTEND_URL="https://votre-frontend.vercel.app"

# Server (port d'écoute)
PORT=5000

# Network configuration
# Pour écouter sur toutes les interfaces réseau (0.0.0.0)
# Décommenter la ligne suivante pour le développement réseau
# HOST=0.0.0.0
