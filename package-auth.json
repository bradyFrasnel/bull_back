{
  "name": "bull-asur-auth",
  "version": "1.0.0",
  "description": "API d'authentification Bull_ASUR",
  "main": "dist/auth-main.js",
  "scripts": {
    "build": "nest build --path tsconfig.json --tsc",
    "start": "node dist/auth-main.js",
    "start:dev": "nest start --watch --entryFile src/auth-main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1"
  }
}
